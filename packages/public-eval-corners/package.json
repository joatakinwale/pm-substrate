{
  "name": "@pm/public-eval-corners",
  "version": "0.1.0",
  "private": true,
  "description": "Pinned provenance, conformance adapters, and fail-closed matched-arm evidence harness for public agent-state corners.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pm-public-eval-corners": "./dist/cli.js",
    "pm-sentinel-anthropic-provider": "./dist/sentinel-anthropic-provider-proxy-cli.js",
    "pm-sentinel-live": "./dist/sentinel-live-runner-cli.js",
    "pm-sentinel-production-smoke": "./dist/sentinel-production-excluded-smoke-cli.js",
    "pm-sentinel-production-batch": "./dist/sentinel-production-batch-cli.js",
    "pm-sentinel-power-audit": "./dist/sentinel-production-power-audit-cli.js",
    "pm-sentinel-production-verify": "./dist/sentinel-production-raw-verifier-cli.js",
    "pm-sentinel-state-sidecar": "./dist/sentinel-state-sidecar-cli.js"
  },
  "dependencies": {
    "@pm/agent-state-core": "workspace:*",
    "@pm/continuity": "workspace:*",
    "@pm/types": "workspace:*",
    "pg": "^8.13.0",
    "playwright": "1.56.1"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "echo \"(tests run from root)\" && true",
    "public-eval-corners": "node dist/cli.js",
    "sentinel-live": "node dist/sentinel-live-runner-cli.js",
    "sentinel-production-smoke": "node dist/sentinel-production-excluded-smoke-cli.js",
    "sentinel-production-verify": "node dist/sentinel-production-raw-verifier-cli.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
