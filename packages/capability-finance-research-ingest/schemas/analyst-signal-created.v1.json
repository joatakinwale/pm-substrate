{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "finance-research/analyst-signal-created.v1.json",
  "type": "object",
  "required": ["researchRunId", "tickerId", "agentId", "signal", "confidence", "occurredAt"],
  "properties": {
    "researchRunId": { "type": "string" },
    "tickerId": { "type": "string" },
    "agentId": { "type": "string" },
    "signal": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "occurredAt": { "type": "string", "format": "date-time" },
    "evidenceDocumentIds": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
