    "test": "echo \"(tests run from root)\" && true"
  },
  "dependencies": {
    "@pm/capability-kit": "workspace:*",
    "@pm/events": "workspace:*",
    "@pm/graph": "workspace:*",
    "@pm/profile-registry": "workspace:*",
    "@pm/profile-wedding": "workspace:*",
    "@pm/registry": "workspace:*",
    "@pm/types": "workspace:*"
  },
  "devDependencies": {
    "@pm/capability-wedding-contracts": "workspace:*",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
