{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wedding.contract.payment_recorded.v1",
  "title": "wedding.contract.payment_recorded v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractId",
    "amount",
    "recordedAt",
    "paymentId"
  ],
  "properties": {
    "contractId": {
      "type": "string",
      "description": "EntityId of the Contract that recorded the payment."
    },
    "amount": {
      "type": "integer",
      "description": "Payment amount in integer minor units."
    },
    "recordedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of when the payment was recorded."
    },
    "paymentId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable caller-assigned idempotency key."
    }
  }
}
