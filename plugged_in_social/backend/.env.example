# ═══════════════════════════════════════════════
# Stevie Social Backend — Environment Variables
# ═══════════════════════════════════════════════
# Copy to .env and fill in your values

# ── Database ───────────────────────────────────
# LOCAL DEV (Docker Compose):
DATABASE_URL=postgresql+asyncpg://stevie:stevie_dev_password@localhost:5432/stevie_dev
DATABASE_URL_SYNC=postgresql+psycopg://stevie:stevie_dev_password@localhost:5432/stevie_dev
# PRODUCTION (Supabase PostgreSQL — get from Supabase → Settings → Database):
# DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DATABASE_URL_SYNC=postgresql+psycopg://postgres.[project-ref]:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── App ─────────────────────────────────────────
APP_ENV=development
DEBUG=true
# General app signing/encryption secret. Generate with:
#   openssl rand -hex 32
# Production startup (app_env=production) will HARD-FAIL if this is left
# at its default or is shorter than 32 characters. Rotate independently
# of CRON_SECRET / WEBHOOK_SECRET / JWT_SECRET_KEY.
SECRET_KEY=change-me-in-production

# ── Internal-endpoint Shared Secrets ────────────
# Used by the Cloudflare cron Worker → FastAPI /internal/cron/*
# header: X-Cron-Secret. Must match the CRON_SECRET binding in
# workers/wrangler.toml. Rotate independently of SECRET_KEY.
CRON_SECRET=change-me-cron-secret
# Used by the Cloudflare webhooks Worker → FastAPI /internal/webhooks/*
# header: X-Webhook-Secret. This is the Worker-↔-FastAPI shared secret,
# NOT the third-party signing secret (e.g. STRIPE_WEBHOOK_SECRET).
WEBHOOK_SECRET=change-me-webhook-secret

# ── Supabase Auth ───────────────────────────────
# Get from Supabase → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ── Custom JWT (dev/testing fallback — used when SUPABASE_JWT_SECRET is empty) ──
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3100,https://stevie.testingjoat.work

# ── Public Frontend URL ─────────────────────────
# Used any time the backend constructs a link a human will click:
# portal magic-links, proposal share URLs, team-invite callbacks,
# unsubscribe links in marketing emails, onboarding emails, etc.
# Dev defaults to localhost:3000 so emails sent from a local worker
# don't redirect test users to prod. Staging/prod override this.
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════
# Cloudflare — Media & Edge
# ═══════════════════════════════════════

# Cloudflare Account
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# R2 Object Storage (S3-compatible — zero egress)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=joatlabstesting
R2_PUBLIC_URL=https://medial.testingjoat.work

# Cloudflare Images
CF_IMAGES_ACCOUNT_HASH=your-images-account-hash
CF_IMAGES_DELIVERY_URL=https://imagedelivery.net/<ACCOUNT_HASH>

# Cloudflare Stream
CF_STREAM_API_TOKEN=your-stream-api-token
CF_STREAM_CUSTOMER_SUBDOMAIN=customer-<code>.cloudflarestream.com

# Workers (deployed separately — URLs filled after wrangler deploy)
CF_WORKER_UPLOAD_URL=https://upload.testingjoat.work
CF_WORKER_CACHE_URL=https://cache.testingjoat.work

# ═══════════════════════════════════════
# Phase 2 — Billing (Stripe)
# ═══════════════════════════════════════

# Get from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook signing secret — from Stripe Dashboard → Developers → Webhooks
# Point webhook to: https://your-domain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════════════════════════════════
# Redis (rate limiting only)
# ═══════════════════════════════════════
# Used by slowapi (MED-2) for rate-limit counters. Background tasks have
# moved to Cloudflare Queues — see QUEUE_PRODUCER_URL below — so Redis is
# no longer a task broker.

# LOCAL DEV (Docker Compose):
REDIS_URL=redis://localhost:6379/0
# PRODUCTION:
# REDIS_URL=redis://default:password@your-redis-host:6379/0

# ═══════════════════════════════════════
# Transactional Email (Resend)
# ═══════════════════════════════════════
# Payment reminders, portal magic-links, onboarding, notifications.
# Marketing bulk sends live elsewhere and intentionally do NOT share
# this key so a leak or a rate-limit on one path doesn't poison the
# other.
RESEND_API_KEY=re_...

# FROM address for every transactional send. Must be a verified sender
# in your Resend account. Format: ``Display Name <inbox@domain.com>``.
# No default in code — set this explicitly per environment so the
# codebase stays brand-agnostic (rename or swap dev domain freely).
# Dev tip: Resend ships `onboarding@resend.dev` as a sandbox sender
# you can use without DNS verification.
RESEND_FROM_EMAIL=Your Product <noreply@your-domain.com>
# Optional — route replies to a monitored inbox. Blank = uses FROM.
RESEND_REPLY_TO=

# ── Cloudflare Workers (Path B+) ─────────────────
# After deploying agents/workers/queue-producer, paste its URL here.
# Empty in dev = task-publish calls REJECT (503) so a queued AI row
# never sits stuck forever. To override for fully-offline local dev:
# set ALLOW_QUEUE_DROP=1 (warns + no-ops). Never set this in prod.
QUEUE_PRODUCER_URL=
# ALLOW_QUEUE_DROP=

# Default model for new AI content generations. Empty = use the
# codepath default (claude-sonnet-4-6). Anything the configured AI
# Gateway provider accepts is fair game:
#   Anthropic: claude-sonnet-4-6, claude-sonnet-4-5, claude-opus-4-7,
#              claude-haiku-4-5
#   OpenAI:    gpt-4o, gpt-4o-mini, gpt-4.1, o3-mini
#   Workers AI: @cf/meta/llama-3.1-8b-instruct,
#               @cf/meta/llama-4-scout-17b-16e-instruct,
#               @cf/openai/gpt-oss-120b
#   Google:    gemini-2.5-pro, gemini-2.5-flash
# The Worker routes by prefix — see agents/workers/ai-content/src/providers.ts.
AI_DEFAULT_MODEL=

# Per content_type model chains (comma-separated). The first entry is
# primary; entries 2+ are fallbacks fed to Cloudflare AI Gateway's
# Universal Endpoint (first 2xx wins, errors fall through). Built-in
# defaults route captions/hashtags to @cf/meta/llama-3.1-8b-instruct
# and long-form to claude-sonnet-4-6 — set these only to override.
# AI_MODEL_CAPTION=@cf/meta/llama-3.1-8b-instruct,gpt-4o-mini
# AI_MODEL_HASHTAGS=@cf/meta/llama-3.1-8b-instruct
# AI_MODEL_BLOG_POST=claude-sonnet-4-6,gpt-4o,claude-haiku-4-5
# AI_MODEL_EMAIL_COPY=
# AI_MODEL_SCRIPT=
#
# Per-org override (preferred over env): set
#   Organization.settings.ai.models.<content_type> = "model-id"   (or)
#   Organization.settings.ai.models.<content_type> = ["m1", "m2"]

# After deploying agents/workers/sse-pubsub, paste its URL here.
# Empty in dev = realtime broadcasts log a warning and no-op.
SSE_PUBSUB_URL=

# Webhook cutover flag. False = Resend webhooks still route through
# FastAPI's legacy /internal/webhooks/resend handler. True = that handler
# short-circuits after signature check because the Resend dashboard URL
# has been repointed at the email-events Cloudflare Worker directly.
# Flip to True only AFTER updating the dashboard or events will be lost.
CF_WORKERS_HANDLE_WEBHOOKS=false

# ── Umami Analytics ─────────────────────────────
# Self-hosted Umami URL (Coolify deploy). No trailing slash.
UMAMI_API_URL=https://stats.testingjoat.work

# Two auth modes — pick one:
#
# (A) Static API key — only available on Umami Cloud or paid self-host
#     builds with team mode enabled. The Profile page in the open-source
#     v3 build does NOT show this section, in which case use (B).
UMAMI_API_KEY=
#
# (B) Username + password fallback for open-source self-host. The
#     backend logs in via POST /api/auth/login on first call, caches
#     the JWT for 23 hours, and re-auths after expiry. Only used when
#     UMAMI_API_KEY is blank.
UMAMI_USERNAME=admin
UMAMI_PASSWORD=

# ── Aurinko (calendar / scheduling / email / contacts) ─────────
# Aurinko replaces Cal.com as the booking provider and additionally
# powers two-way calendar sync, contacts sync, and (future) email
# send + tracking. Each org owner connects ONE Google or Microsoft
# account through the OAuth flow at
#   /api/integrations/aurinko/authorize → Aurinko → /api/integrations/aurinko/callback
# Group / round-robin booking only requires connecting a second
# account on the same org.
#
# Get the client id + secret from the Aurinko portal (Apps → your
# application → Credentials). Set the application's return URL to
#   ${PUBLIC_APP_URL}/api/integrations/aurinko/callback
# and configure the webhook destination to point at
#   ${PUBLIC_APP_URL}/internal/webhooks/aurinko
AURINKO_CLIENT_ID=
AURINKO_CLIENT_SECRET=
# Shared secret used to verify the X-Aurinko-Signature header on every
# inbound webhook AND to satisfy Aurinko's URL verification handshake.
# Must match the value on the Aurinko application config.
AURINKO_SIGNING_SECRET=
# Override only for a regional Aurinko endpoint.
AURINKO_BASE_URL=https://api.aurinko.io/v1

# ── Seed Script ─────────────────────────────────
# Set to Supabase auth.users.id of your admin after creating in Supabase dashboard
# SUPABASE_ADMIN_AUTH_ID=

# ── Test User (dev + E2E login) ────────────────
# Use the email/password of your real Supabase Auth user (from Auth → Users).
# To set a password directly (no email flow), run via supabase SQL editor or MCP:
#   UPDATE auth.users
#   SET encrypted_password = crypt('YourDevPassword', gen_salt('bf')),
#       updated_at = NOW()
#   WHERE id = '<your-auth-uid>';
TEST_USER_EMAIL=your-real-auth-email@example.com
TEST_USER_PASSWORD=
TEST_USER_AUTH_ID=


