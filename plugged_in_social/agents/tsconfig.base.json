{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    // exactOptionalPropertyTypes is intentionally OFF. It requires every
    // optional field to explicitly include `| undefined` in its type, which
    // forces noisy union types on every Worker payload. The strict flag
    // catches almost-zero real bugs in our HTTP-shaped code.
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowSyntheticDefaultImports": true
  }
}
