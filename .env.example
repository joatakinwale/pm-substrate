# PM-substrate local dev configuration

# Postgres connection (matches docker-compose defaults)
PM_DATABASE_URL=postgres://pm:pm_dev_password@127.0.0.1:5432/pm_substrate

# Tenant scope for local development. Single tenant is fine for day-1 work,
# but every layer is partitioned by tenant_id from the start (architecture rule).
PM_DEV_TENANT_ID=tenant_dev

# Logging
PM_LOG_LEVEL=info
