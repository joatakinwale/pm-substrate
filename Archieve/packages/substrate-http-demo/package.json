{
  "name": "@pm/substrate-http-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Sample server entry point demonstrating the profile-agnostic @pm/substrate-http API. NOT part of the substrate library; a runnable demo for docker-compose and local development.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "echo \"(tests run from root)\" && true"
  },
  "dependencies": {
    "@pm/capability-finance-research-ingest": "workspace:*",
    "@pm/events": "workspace:*",
    "@pm/graph": "workspace:*",
    "@pm/profile-finance-research": "workspace:*",
    "@pm/profile-registry": "workspace:*",
    "@pm/projections": "workspace:*",
    "@pm/registry": "workspace:*",
    "@pm/substrate-http": "workspace:*",
    "@pm/tenants": "workspace:*",
    "@pm/types": "workspace:*",
    "hono": "^4.12.16",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}
