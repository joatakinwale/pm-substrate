  },
  "dependencies": {
    "@pm/agent-state-core": "workspace:*",
    "@pm/public-eval-analysis": "workspace:*",
    "@pm/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.1.0"
  }
}
