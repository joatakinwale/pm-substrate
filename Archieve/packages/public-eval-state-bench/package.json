{
  "name": "@pm/public-eval-state-bench",
  "version": "0.1.0",
  "private": true,
  "description": "Peripheral STATE-Bench Agent Learning Track adapter for public pm-substrate validation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
